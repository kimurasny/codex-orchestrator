# Codex Orchestrator 設定サンプル
#
# パスの基準:
#   - project_root … 解析対象リポジトリのルート。相対の場合はこの設定ファイルの
#                     配置ディレクトリ基準。別リポジトリを解析する場合は下記のように
#                     絶対パスを指定する（対象ファイルはここを基準に存在チェック・解析）。
#   - output_dir  … 相対の場合は project_root 基準（解析対象プロジェクト配下に出力）。
#   - その他のパス（targets_file / templates_dir / status_file / log_file）…
#                     project_root ではなく設定ファイルの配置ディレクトリ基準で解決される。
#                     このためテンプレート・対象一覧・ログはオーケストレーター側に留まる。

# 解析対象プロジェクトのルート（別リポジトリを解析する Windows 例）
project_root: D:/git/project

# 対象ファイル一覧（設定ファイル配置ディレクトリ基準。1 行 1 相対パスで project_root からの相対）
targets_file: config/targets.txt

# 使用テンプレート名（templates/ 配下の Markdown。拡張子省略可）
template: class_spec

# Markdown 出力ディレクトリ（project_root 基準 → 解析対象プロジェクト配下に出力）
output_dir: docs/spec

# 既存出力の扱い: overwrite（上書き） / skip（既存はスキップ）
output_mode: overwrite

# Codex の標準出力を仕様書ファイルとして保存するか。
# false: 保存しない（Codex 自身が {{OUTPUT}} にファイルを書き出す前提。標準出力で上書きしない）
# true : 標準出力を仕様書ファイルとして保存する（従来動作）
save_stdout: false

# 相対ディレクトリ構造を保持するか
preserve_directory: true

# 失敗時の最大リトライ回数
retry: 3

# Codex CLI 実行コマンド
codex_command: codex exec --sandbox workspace-write

# テンプレート配置ディレクトリ
templates_dir: templates

# 実行状態ファイル / 実行ログ
status_file: logs/status.json
log_file: logs/run.log

# テキスト読込時のエンコーディング候補（BOM 付き/無し UTF-8 を基本に Shift_JIS へフォールバック）
encoding_candidates:
  - utf-8-sig
  - cp932
